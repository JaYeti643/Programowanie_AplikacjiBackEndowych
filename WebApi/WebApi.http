@WebApi_HostAddress=https://localhost:5002

###

### Pobierz wszystkie firmy
GET {{WebApi_HostAddress}}/api/companies?page=1&pageSize=10
Accept: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..5Q5EfFaZfunJl8ErCayweJU2P7oUt109VQnjUgE1uMw

###

### Pobierz firmę według ID
GET {{WebApi_HostAddress}}/api/companies/c63dae88-7f8d-4c53-a98f-7dc197dfb7e0
Accept: application/json

###

    ### Dodaj nową firmę
POST {{WebApi_HostAddress}}/api/companies
Content-Type: application/json

{
  "name": "Google Poland",
  "nip": "3010000003",
  "regon": "140000001",
  "krs": "0000123456",
  "industry": "Software Development",
  "employeeCount": 1000,
  "annualRevenue": 10000000000.00,
  "website": "https://google.pl",
  "email": "contact@google.pl",
  "phone": "48-12-123-45-67",
  "address": {
    "street": "ul. Prosta 51",
    "city": "Kraków",
    "postalCode": "00-025",
    "country": "Poland",
    "type": "Main"
  }
}

###

### Zaktualizuj firmę
PUT {{WebApi_HostAddress}}/api/companies/c63dae88-7f8d-4c53-a98f-7dc197dfb7e0
Content-Type: application/json

{
  "name": "Tech Corp Poland Updated",
  "industry": "Enterprise Software",
  "employeeCount": 100,
  "annualRevenue": 750052000.00
}

###

### Usuń firmę
DELETE {{WebApi_HostAddress}}/api/companies/aa758468-5749-445a-b971-53283ead3478
Accept: application/json

###

### Znajdz firme po nazwie
GET {{WebApi_HostAddress}}/api/companies/search/name?nameOrPart=G
Accept: application/json

###

### Znajdź firmę po numerze NIP
GET {{WebApi_HostAddress}}/api/companies/search/nip?nip=3010000003
Accept: application/json
###

### Pobierz wszystkich pracowników firmy
GET {{WebApi_HostAddress}}/api/companies/c63dae88-7f8d-4c53-a98f-7dc197dfb7e0/employees?sortBy=LastName&descending=false
Accept: application/json

###

### Pobierz pracowników z filtrami
GET {{WebApi_HostAddress}}/api/companies/c63dae88-7f8d-4c53-a98f-7dc197dfb7e0/employees?lastName=Dro
Accept: application/json

###

### Szukaj pracowników według kryteriów
GET {{WebApi_HostAddress}}/api/companies/c63dae88-7f8d-4c53-a98f-7dc197dfb7e0/employees/search?firstName=Karol
Accept: application/json

###

### Dodaj pracownika do firmy
POST {{WebApi_HostAddress}}/api/companies/c63dae88-7f8d-4c53-a98f-7dc197dfb7e0/employees/698c7930-cf0f-4131-901d-df998ea38caa
Accept: application/json

###

### Usuń pracownika z firmy
DELETE {{WebApi_HostAddress}}/api/companies/c63dae88-7f8d-4c53-a98f-7dc197dfb7e0/employees/c1bd7569-fc86-484d-8720-b172c6e4f406
Accept: application/json

###

### Pobierz liczbę pracowników w firmie
GET {{WebApi_HostAddress}}/api/companies/c63dae88-7f8d-4c53-a98f-7dc197dfb7e0/employees/count
Accept: application/json

